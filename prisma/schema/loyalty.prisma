model LoyaltyRule {
  id          String      @id @default(cuid())
  propertyId  String?     // null = всі готелі
  tier        LoyaltyTier
  discountPct Int         @default(0)
  minNights   Int         @default(0)
  bonusPoints Int         @default(0)

  // Сертифікат після виїзду (UAH)
  certAmount     Decimal  @default(0) @db.Decimal(10, 2)
  // Реферальний бонус (UAH)
  referralBonus  Decimal  @default(0) @db.Decimal(10, 2)
  // Пріоритет якщо кілька правил підходять
  priority       Int      @default(10)

  description String?
  isActive    Boolean     @default(true)
  validFrom   DateTime?   @db.Date
  validUntil  DateTime?   @db.Date

  @@index([tier])
  @@map("loyalty_rules")
}

model ReferralLink {
  id          String       @id @default(cuid())
  referrerId  String?
  referrer    GuestProfile? @relation(fields: [referrerId], references: [id])
  code        String       @unique
  token       String?      @unique  // для URL /ref/<token>
  discountPct Int          @default(5)
  clicks      Int          @default(0)
  conversions Int          @default(0)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())

  usages   ReferralUsage[]
  bookings Booking[]

  @@index([referrerId])
  @@map("referral_links")
}

model ReferralUsage {
  id              String        @id @default(cuid())
  referralLinkId  String
  guestId         String?
  bookingId       String?
  bonusAmount     Decimal       @default(0) @db.Decimal(10, 2)
  bonusCreditedAt DateTime?
  createdAt       DateTime      @default(now())

  referralLink ReferralLink  @relation(fields: [referralLinkId], references: [id])
  guest        GuestProfile? @relation(fields: [guestId], references: [id])

  @@index([referralLinkId])
  @@map("referral_usages")
}
