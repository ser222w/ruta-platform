model Property {
  id         String   @id @default(cuid())
  slug       String   @unique
  name       String
  city       String?
  region     String?
  totalRooms Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  // Префікс номера бронювання: P/B/Z/T
  bookingPrefix    String?  @db.Char(1)

  // LiqPay credentials (окремі для кожного готелю — різні юридичні особи)
  liqpayPublicKey  String?
  liqpayPrivateKey String?  // зберігається зашифрованим

  // Контакти
  address  String?
  phone    String?
  email    String?
  website  String?

  roomCategories RoomCategory[]
  bookings       Booking[]
  promotions     Promotion[]
  inquiries      Inquiry[]
  inboxes        Inbox[]
}

model RoomCategory {
  id          String   @id @default(cuid())
  propertyId  String
  name        String
  capacity    Int      @default(2)
  totalRooms  Int      @default(1)
  description String?
  amenities   String[]
  imageUrls   String[]
  isActive    Boolean  @default(true)

  property     Property          @relation(fields: [propertyId], references: [id])
  tariffLines  TariffLine[]
  bookingLines BookingRoomLine[]
}

model Tariff {
  id         String    @id @default(cuid())
  propertyId String?
  name       String
  mealPlan   MealPlan  @default(BB)
  isActive   Boolean   @default(true)
  validFrom  DateTime?
  validUntil DateTime?
  createdAt  DateTime  @default(now())

  lines    TariffLine[]
  bookings Booking[]
}

model TariffLine {
  id               String  @id @default(cuid())
  tariffId         String
  roomCategoryId   String
  pricePerNight    Decimal @db.Decimal(12, 2)
  minNights        Int     @default(1)
  weekendSurcharge Decimal @default(0) @db.Decimal(12, 2)

  tariff       Tariff       @relation(fields: [tariffId], references: [id])
  roomCategory RoomCategory @relation(fields: [roomCategoryId], references: [id])
}

// ─────────────────────────────────────────────
// PROMOTION (знижки, акції, пакети)
// ─────────────────────────────────────────────

enum PromotionType {
  EARLY_BIRD   // знижка за раннє бронювання
  LAST_MINUTE  // знижка в останній момент
  LONG_STAY    // знижка за тривале проживання
  PACKAGE      // пакет послуг
  SEASONAL     // сезонна акція
  LOYALTY      // знижка для лояльних гостей
  SPECIAL      // спеціальна пропозиція
}

model Promotion {
  id              String        @id @default(cuid())
  propertyId      String?       // null = всі готелі
  property        Property?     @relation(fields: [propertyId], references: [id])

  name            String
  code            String?       @unique  // e.g. "EARLY30"
  type            PromotionType

  // Вікно бронювання (коли акція активна)
  bookingDateFrom DateTime?     @db.Date
  bookingDateTo   DateTime?     @db.Date
  // Вікно проживання (до яких дат заїзду застосовується)
  stayDateFrom    DateTime?     @db.Date
  stayDateTo      DateTime?     @db.Date

  discountPct     Decimal?      @db.Decimal(5, 2)
  discountAmount  Decimal?      @db.Decimal(10, 2)

  // Перевизначає стандартний prepay тарифу
  prepayPctOverride Int?

  minNights       Int?
  minGuests       Int?

  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([propertyId])
  @@map("promotions")
}
