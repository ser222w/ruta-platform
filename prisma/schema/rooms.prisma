model Property {
  id         String   @id @default(cuid())
  slug       String   @unique
  name       String
  city       String?
  region     String?
  totalRooms Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  roomCategories RoomCategory[]
  bookings       Booking[]
}

model RoomCategory {
  id          String   @id @default(cuid())
  propertyId  String
  name        String
  capacity    Int      @default(2)
  totalRooms  Int      @default(1)
  description String?
  amenities   String[]
  imageUrls   String[]
  isActive    Boolean  @default(true)

  property     Property          @relation(fields: [propertyId], references: [id])
  tariffLines  TariffLine[]
  bookingLines BookingRoomLine[]
}

model Tariff {
  id         String    @id @default(cuid())
  propertyId String?
  name       String
  mealPlan   MealPlan  @default(BB)
  isActive   Boolean   @default(true)
  validFrom  DateTime?
  validUntil DateTime?
  createdAt  DateTime  @default(now())

  lines    TariffLine[]
  bookings Booking[]
}

model TariffLine {
  id               String  @id @default(cuid())
  tariffId         String
  roomCategoryId   String
  pricePerNight    Decimal @db.Decimal(12, 2)
  minNights        Int     @default(1)
  weekendSurcharge Decimal @default(0) @db.Decimal(12, 2)

  tariff       Tariff       @relation(fields: [tariffId], references: [id])
  roomCategory RoomCategory @relation(fields: [roomCategoryId], references: [id])
}
